  "type": "Makkiyah",
  "verses": [
    {
      "number": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ هُوَ ٱللَّهُ أَحَدٌ",
      "translation_en": "Say, \"He is Allah, [who is] One,",
      "translation_bn": "বলুন, তিনি আল্লাহ, এক,"
    },
    {
      "number": 2,
      "text": "ٱللَّهُ ٱلصَّمَدُ",
      "translation_en": "Allah, the Eternal Refuge.",
      "translation_bn": "আল্লাহ অমুখাপেক্ষী,"
    },
    {
      "number": 3,
      "text": "لَمْ يَلِدْ وَلَمْ يُولَدْ",
      "translation_en": "He neither begets nor is born,",
      "translation_bn": "তিনি কাউকে জন্ম দেননি এবং কেউ তাকে জন্ম দেয়নি"
    },
    {
      "number": 4,
      "text": "وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ",
      "translation_en": "Nor is there to Him any equivalent.\"",
      "translation_bn": "এবং তার সমতুল্য কেউ নেই।"
    }
  ]
}