  "type": "Makkiyah",
  "verses": [
    {
      "number": 1,
      "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْعَصْرِ",
      "translation_en": "By time,",
      "translation_bn": "কসম যুগের (সময়ের),"
    },
    {
      "number": 2,
      "text": "إِنَّ ٱلْإِنسَٰنَ لَفِى خُسْرٍ",
      "translation_en": "Indeed, mankind is in loss,",
      "translation_bn": "নিশ্চয় মানুষ ক্ষতিগ্রস্ত;"
    },
    {
      "number": 3,
      "text": "إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ وَتَوَاصَوْا۟ بِٱلْحَقِّ وَتَوَاصَوْا۟ بِٱلصَّبْرِ",
      "translation_en": "Except for those who have believed and done righteous deeds and advised each other to truth and advised each other to patience.",
      "translation_bn": "কিন্তু তারা নয়, যারা বিশ্বাস স্থাপন করে ও সৎকর্ম করে এবং পরস্পরকে তাকীদ করে সত্যের এবং তাকীদ করে সবরের।"
    }
  ]
}